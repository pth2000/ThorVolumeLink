    <string name="app_title">Thor Volume Link</string>
    <string name="app_subtitle">Dual-screen volume routing and synchronization for AYN Thor.</string>
    <string name="service_description">Handles the mode-switch key and volume keys to control the primary screen, secondary screen, both screens, or the most recently interacted-with screen. The service does not inspect screen content.</string>

