<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:text="@string/app_title" />

            <TextView
                android:id="@+id/edition_badge"
                style="@style/TextLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/status_neutral"
                android:paddingLeft="10dp"
                android:paddingTop="6dp"
                android:paddingRight="10dp"
                android:paddingBottom="6dp"
                android:text="@string/edition_name" />

            <ImageButton
                android:id="@+id/open_settings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/button_outline"
                android:contentDescription="@string/settings"
                android:padding="10dp"
                android:src="@drawable/ic_settings" />
        </LinearLayout>

        <include layout="@layout/view_status_card" />

        <LinearLayout
            android:id="@+id/first_use_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                style="@style/TextSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/first_use_title" />

            <TextView
                style="@style/TextBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/first_use_description" />

            <Button
                android:id="@+id/open_key_controls"
                style="@style/ButtonFilled"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:text="@string/open_key_controls" />

            <Button
                android:id="@+id/dismiss_first_use"
                style="@style/ButtonTonal"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:text="@string/not_now" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                style="@style/TextSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_mode" />

            <TextView
                android:id="@+id/mode_status"
                style="@style/TextHeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/mode_sync" />

            <TextView
                android:id="@+id/mode_description"
                style="@style/TextBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="@string/mode_sync_description" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/mode_main"
                    style="@style/ButtonSegment"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/segment_unselected"
                    android:text="@string/mode_main" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/mode_secondary"
                    style="@style/ButtonSegment"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/segment_unselected"
                    android:text="@string/mode_secondary" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <Button
                    android:id="@+id/mode_sync"
                    style="@style/ButtonSegment"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/segment_selected"
                    android:text="@string/mode_sync" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                style="@style/TextSection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_volume" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/main_volume_status"
                    style="@style/TextValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/status_neutral"
                    android:padding="14dp"
                    android:text="@string/main_volume" />

                <View android:layout_width="8dp" android:layout_height="1dp" />

                <TextView
                    android:id="@+id/secondary_volume_status"
                    style="@style/TextValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/status_neutral"
                    android:padding="14dp"
                    android:text="@string/secondary_volume" />
            </LinearLayout>

            <Button
                android:id="@+id/sync_now"
                style="@style/ButtonOutline"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="@string/sync_now" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
